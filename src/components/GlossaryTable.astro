---
interface Ref {
  title: string;
  slug: string;
}
interface Mention {
  subject: string;
  refs: Ref[];
}
interface Entry {
  id: string;
  letter: string;
  abbr: string;
  full: string;
  description: string;
  mentions: Mention[];
}
interface Props {
  entries: Entry[];
}

const { entries } = Astro.props;

const groups = new Map<string, Entry[]>();
for (const entry of entries) {
  if (!groups.has(entry.letter)) groups.set(entry.letter, []);
  groups.get(entry.letter)!.push(entry);
}

const letters = [...groups.keys()].sort((a, b) => {
  if (a === "µ") return 1;
  if (b === "µ") return -1;
  return a.localeCompare(b, "en");
});
---

<p>
  {letters.map((l, i) => (
    <>
      {i > 0 && " · "}
      <a href={`#letter-${l.toLowerCase()}`}>{l}</a>
    </>
  ))}
</p>

<hr />

{
  letters.map((letter) => (
    <section>
      <h2 id={`letter-${letter.toLowerCase()}`}>{letter}</h2>
      <table>
        <thead>
          <tr>
            <th>Съкращение</th>
            <th>Пълно наименование</th>
            <th>Описание</th>
            <th>Източници</th>
          </tr>
        </thead>
        <tbody>
          {groups.get(letter)!.map((entry) => (
            <tr>
              <td>
                <a id={entry.id}>
                  <strong>{entry.abbr}</strong>
                </a>
              </td>
              <td>{entry.full}</td>
              <td>{entry.description}</td>
              <td>
                {entry.mentions.flatMap((m, mi) =>
                  m.refs.map((r, ri) => (
                    <>
                      {(mi > 0 || ri > 0) && ", "}
                      <a href={`/${m.subject}/${r.slug}/`}>{r.title}</a>
                    </>
                  ))
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  ))
}

<hr />

<p>
  <em>Речникът обхваща съкращенията от всички предмети. При несъответствие —
    меродавен е текстът на съответната глава.</em>
</p>
