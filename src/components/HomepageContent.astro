---
import TopicCards from "@/components/TopicCards.astro";

interface Chapter {
  num: number;
  slug: string;
  title: string;
  topics: string[];
}
interface TopicCard {
  title: string;
  icon: string;
  description: string;
}
interface HomepageData {
  courseInfo: { specialty: string; department: string; lecturer: string };
  topicCards: TopicCard[];
  chapters: Chapter[];
}
interface Props {
  data: HomepageData;
  base: string;
}

const { data: homepage, base } = Astro.props;
---

<h2>Теми</h2>

<TopicCards cards={homepage.topicCards} />

<hr />

<h2>Конспект</h2>

{
  homepage.chapters.map((ch) => (
    <details open>
      <summary>
        <strong>
          Глава {ch.num} — <a href={`/${base}/${ch.slug}/`}>{ch.title}</a>
        </strong>
      </summary>
      {ch.topics.length > 0 && (
        <ol>
          {ch.topics.map((topic) => (
            <li>{topic}</li>
          ))}
        </ol>
      )}
    </details>
  ))
}
