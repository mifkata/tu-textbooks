---
import { Card, CardGrid } from "@astrojs/starlight/components";

interface Chapter {
  num: number;
  slug: string;
  title: string;
  topics: string[];
}
interface TopicCard {
  title: string;
  icon: string;
  description: string;
}
interface HomepageData {
  courseInfo: { specialty: string; department: string; lecturer: string };
  topicCards: TopicCard[];
  chapters: Chapter[];
}
interface Props {
  data: HomepageData;
  base: string;
}

const { data: homepage, base } = Astro.props;
---

<p>
  <strong>Специалност:</strong>
  {homepage.courseInfo.specialty}<br />
  <strong>Катедра:</strong>
  {homepage.courseInfo.department}<br />
  <strong>Лектор:</strong>
  {homepage.courseInfo.lecturer}
</p>

<hr />

<h2>Теми</h2>

<CardGrid>
  {
    homepage.topicCards.map((card) => (
      <Card title={card.title} icon={card.icon as any}>
        {card.description}
      </Card>
    ))
  }
</CardGrid>

<hr />

<h2>Конспект</h2>

{
  homepage.chapters.map((ch) => (
    <details open>
      <summary>
        <strong>
          Глава {ch.num} — <a href={`/${base}/${ch.slug}/`}>{ch.title}</a>
        </strong>
      </summary>
      {ch.topics.length > 0 && (
        <ol>
          {ch.topics.map((topic) => (
            <li>{topic}</li>
          ))}
        </ol>
      )}
    </details>
  ))
}

<p><a href="/glossary/"><strong>→ Речник на съкращенията</strong></a></p>
