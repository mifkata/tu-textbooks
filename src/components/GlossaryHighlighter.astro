---
// Injected site-wide via Starlight Footer override.
// Loads glossary non-blocking, then highlights matching terms in page content.
---

<div id="gl-root"></div>

<script>
  import { createRoot } from 'react-dom/client';
  import { createElement } from 'react';
  import GlossaryPopup from './GlossaryPopup';
  import type { GlossaryEntry } from './GlossaryPopup';

  type PopupState = { entry: GlossaryEntry; anchor: DOMRect } | null;

  let root: ReturnType<typeof createRoot> | null = null;
  let closeTimer: ReturnType<typeof setTimeout> | null = null;
  let pinned = false;

  function clearClose() {
    if (closeTimer !== null) { clearTimeout(closeTimer); closeTimer = null; }
  }

  function scheduleClose(delay = 200) {
    if (pinned) return;
    clearClose();
    closeTimer = setTimeout(() => renderPopup(null), delay);
  }

  function renderPopup(state: PopupState, isPinned = false) {
    if (!isPinned) pinned = false;
    if (!root) {
      const el = document.getElementById('gl-root')!;
      root = createRoot(el);
    }
    if (!state) {
      pinned = false;
      root.render(null);
      return;
    }
    root.render(
      createElement(GlossaryPopup, {
        entry: state.entry,
        anchor: state.anchor,
        pinned: isPinned,
        onClose: () => { pinned = false; renderPopup(null); },
        onMouseEnter: clearClose,
        onMouseLeave: scheduleClose,
      })
    );
  }

  // ── DOM scanning ──────────────────────────────────────────────────────────

  const SKIP_TAGS = new Set(['CODE', 'PRE', 'A', 'BUTTON', 'H1', 'H2', 'H3', 'H4', 'H5', 'H6', 'SCRIPT', 'STYLE']);

  function buildIndex(entries: GlossaryEntry[]) {
    // Filter out single-letter abbreviations
    const valid = entries.filter(e => e.abbr.length > 1);
    // Sort longest first to prefer longer matches
    valid.sort((a, b) => b.abbr.length - a.abbr.length || b.full.length - a.full.length);

    const byAbbr = new Map<string, GlossaryEntry>();
    const byFull = new Map<string, GlossaryEntry>();
    for (const e of valid) {
      byAbbr.set(e.abbr, e);
      byFull.set(e.full.toLowerCase(), e);
    }

    // Build combined regex: abbr (exact uppercase words) | full names (case-insensitive)
    const abbrPatterns = [...byAbbr.keys()].map(s => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
    const fullPatterns = [...byFull.keys()].map(s => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));

    const allPatterns = [...abbrPatterns, ...fullPatterns];
    if (!allPatterns.length) return null;

    const regex = new RegExp(`\\b(${allPatterns.join('|')})\\b`, 'gi');
    return { regex, byAbbr, byFull };
  }

  function processTextNode(
    node: Text,
    index: { regex: RegExp; byAbbr: Map<string, GlossaryEntry>; byFull: Map<string, GlossaryEntry> }
  ): Node[] | null {
    const text = node.textContent ?? '';
    index.regex.lastIndex = 0;
    let match: RegExpExecArray | null;
    let last = 0;
    const parts: Node[] = [];

    while ((match = index.regex.exec(text)) !== null) {
      const matchText = match[0];
      const lower = matchText.toLowerCase();
      const entry = index.byAbbr.get(matchText) ?? index.byFull.get(lower);
      if (!entry) continue;

      if (match.index > last) {
        parts.push(document.createTextNode(text.slice(last, match.index)));
      }

      const btn = document.createElement('button');
      btn.className = 'gl-term';
      btn.dataset.gid = entry.id;
      btn.textContent = matchText;
      btn.addEventListener('mouseenter', () => {
        clearClose();
        renderPopup({ entry, anchor: btn.getBoundingClientRect() }, pinned);
      });
      btn.addEventListener('mouseleave', () => scheduleClose());
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        pinned = !pinned;
        renderPopup({ entry, anchor: btn.getBoundingClientRect() }, pinned);
      });
      parts.push(btn);
      last = match.index + matchText.length;
    }

    if (!parts.length) return null;
    if (last < text.length) parts.push(document.createTextNode(text.slice(last)));
    return parts;
  }

  function scanContent(index: ReturnType<typeof buildIndex>) {
    if (!index) return;
    const container = document.querySelector('.sl-markdown-content');
    if (!container) return;

    const walker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        let p = node.parentElement;
        while (p && p !== container) {
          if (SKIP_TAGS.has(p.tagName)) return NodeFilter.FILTER_REJECT;
          p = p.parentElement;
        }
        return NodeFilter.FILTER_ACCEPT;
      },
    });

    const toReplace: Array<{ node: Text; parts: Node[] }> = [];
    let current: Text | null;
    while ((current = walker.nextNode() as Text | null)) {
      const parts = processTextNode(current, index);
      if (parts) toReplace.push({ node: current, parts });
    }

    for (const { node, parts } of toReplace) {
      const frag = document.createDocumentFragment();
      for (const p of parts) frag.appendChild(p);
      node.parentNode?.replaceChild(frag, node);
    }
  }

  // ── Boot ──────────────────────────────────────────────────────────────────

  function init() {
    fetch('/glossary-index.json')
      .then(r => r.json())
      .then((entries: GlossaryEntry[]) => {
        const index = buildIndex(entries);
        scanContent(index);
      })
      .catch(() => { /* silently skip if glossary unavailable */ });
  }

  if ('requestIdleCallback' in window) {
    requestIdleCallback(init, { timeout: 2000 });
  } else {
    setTimeout(init, 50);
  }
</script>
