---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import GlossaryTable from '@/components/GlossaryTable.astro';
import glossaryData from '@/glossary/glossary-index.json';
---

<StarlightPage
  frontmatter={{
    title: 'Справочник на термините',
    description: 'Глобален справочник на термините и съкращенията, използвани в курсовете',
  }}
>
  <p>
    Глобален справочник на термините и съкращенията, използвани в учебните материали.
    Всеки термин е уникален — при двусмислие е добавена бележка.
  </p>

  <GlossaryTable entries={glossaryData} />
</StarlightPage>
